        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"worker123\",\n  \"email\": \"worker@example.com\",\n  \"password\": \"Secret123!\",\n  \"firstName\": \"First\",\n  \"secondName\": \"Last\",\n  \"role\": \"WORKER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login as Worker",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = {};",
                  "try { json = pm.response.json(); } catch (e) { }",
                  "var token = json.token || json.accessToken || json.jwt || (json.data && json.data.token);",
                  "if (token) { pm.collectionVariables.set('authToken', token); }",
                  "pm.test('Save auth token', function() { pm.expect(token).to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"worker@example.com\",\n  \"password\": \"Secret123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
