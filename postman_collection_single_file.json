    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "clientId",
      "value": ""
    },
    {
      "key": "workerUserId",
      "value": ""
    },
    {
      "key": "workerProfileId",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "senderId",
      "value": ""
    },
    {
      "key": "receiverId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
